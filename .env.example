# Copy this file to .env.local for local development.
# In production these are set in Vercel: Project → Settings → Environment Variables.
# See concept/11-config-specification.md for the full explanation of each.

# --- Clash of Clans ---
COC_API_TOKEN=
COC_API_BASE_URL=https://cocproxy.royaleapi.dev/v1

# --- Database (auto-populated once you add the Neon integration in Vercel) ---
DATABASE_URL=

# --- Ingestion security ---
# Generate with: openssl rand -hex 32
INGEST_SECRET=
# Vercel provisions CRON_SECRET automatically when you add a Cron Job —
# you don't set this one by hand in production, but a local placeholder
# is needed to run /api/cron/purge locally.
CRON_SECRET=
