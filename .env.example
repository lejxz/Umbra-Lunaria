# Copy this file to .env.local for local development.
# In production these are set in Vercel: Project → Settings → Environment Variables.
# See concept/11-config-specification.md for the full explanation of each.

# --- Clash of Clans ---
COC_API_TOKEN=
COC_API_BASE_URL=https://cocproxy.royaleapi.dev/v1

# --- DATABASE_URL is required for local dev. Set up a Supabase project, go to
# Project Settings -> Database, and copy the Transaction Pooler connection string (port 6543).
DATABASE_URL=

# --- Ingestion security ---
# Generate both with: openssl rand -hex 32
# INGEST_SECRET is sent as `Authorization: Bearer <INGEST_SECRET>` by the
# third-party cron-job service that triggers /api/ingest (see concept/04).
INGEST_SECRET=
# Vercel does NOT generate this for you — set it yourself, same as
# INGEST_SECRET. Vercel then automatically sends it as the Authorization
# header when it invokes /api/cron/purge on schedule.
CRON_SECRET=
